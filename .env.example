# Reference only. FrameProof does not load .env files automatically.

# Required for Figma API operations. Use the narrowest scopes possible.
FIGMA_TOKEN=

# Optional. Image bytes are sent to TinyJPG/Tinify when compression is enabled.
TINYJPG_TOKEN=

# Optional browser executable paths for the visual gate. CHROME_BIN is checked first.
CHROME_BIN=
CHROMIUM_BIN=

# Optional JSON array of {"name":"...","value":"...","url":"https://..."}.
# Cookie values are credentials; never commit a populated value.
FRAMEPROOF_COOKIES_JSON=

# Optional safe root for MCP-generated files. Defaults to the MCP process working directory.
# Parser and visual-gate output flags remain separate from this MCP boundary.
FRAMEPROOF_OUTPUT_ROOT=

# Remote MCP mutations are blocked unless this value is exactly 1.
FRAMEPROOF_ENABLE_WRITES=0
