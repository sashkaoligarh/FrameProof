{
  "name": "figma-scaler",
  "version": "0.1.0",
  "private": true,
  "description": "Pixel-perfect Figma token, orchestration, and visual gate toolkit for AI-assisted React/Astro development",
  "type": "module",
  "bin": {
    "figma-scaler": "./dist/cli.js",
    "mcp": "./dist/mcp/server.js"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "build": "tsc",
    "build:mcp": "tsc",
    "mcp:start": "node dist/mcp/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "dev": "tsc --watch"
  },
  "keywords": [
    "figma",
    "design-tokens",
    "css",
    "parser"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "commander": "^14.0.3",
    "playwright-core": "^1.59.1",
    "pngjs": "^7.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@figma/rest-api-spec": "^0.36.0",
    "@types/css-tree": "^2.3.11",
    "@types/node": "^25.3.2",
    "@types/pngjs": "^6.0.5",
    "css-tree": "^3.1.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
